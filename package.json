{
    "name": "edgebase",
    "version": "0.1.5",
    "type": "module",
    "private": true,
    "scripts": {
        "preinstall": "node ./scripts/check-node-version.mjs",
        "build": "pnpm -r --if-present run build",
        "lint": "pnpm -r --if-present run lint",
        "test": "pnpm -r --if-present run test && pnpm --dir packages/server run test:integration",
        "test:unit": "pnpm -r --if-present run test",
        "dev": "./scripts/dev.sh",
        "build:turbo": "turbo run build",
        "lint:turbo": "turbo run lint",
        "test:turbo": "turbo run test",
        "dev:turbo": "turbo run dev",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
        "skills:generate": "node ./tools/agent-skill-gen/generate.mjs",
        "skills:list-generated": "node ./tools/agent-skill-gen/list-generated-paths.mjs",
        "skills:verify": "node ./tools/agent-skill-gen/verify.mjs",
        "release:sync": "node ./scripts/sync-release-versions.mjs",
        "release:check": "node ./scripts/check-release-versions.mjs",
        "release:set": "node ./scripts/set-release-version.mjs",
        "release:npm": "node ./dev/release/publish-npm-release.mjs",
        "release:pub": "node ./dev/release/publish-pub-release.mjs",
        "release:pypi": "node ./dev/release/publish-pypi-release.mjs",
        "release:crates": "node ./dev/release/publish-rust-release.mjs",
        "release:nuget": "node ./dev/release/publish-nuget-release.mjs",
        "release:rubygems": "node ./dev/release/publish-rubygems-release.mjs",
        "release:hex": "node ./dev/release/publish-hex-release.mjs",
        "release:php-sync": "node ./dev/release/sync-php-split-release.mjs",
        "release:swift-sync": "node ./dev/release/sync-swift-split-release.mjs",
        "release:jitpack": "node ./dev/release/verify-jitpack-release.mjs"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/ws": "^8.18.1",
        "eslint": "^9.20.0",
        "prettier": "^3.5.0",
        "turbo": "^2.4.0",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.55.0",
        "ws": "^8.19.0"
    },
    "engines": {
        "node": ">=20.19.0"
    },
    "packageManager": "pnpm@9.15.0",
    "pnpm": {
        "overrides": {
            "ajv@>=6.0.0 <6.14.0": "6.14.0",
            "ajv@>=8.0.0 <8.18.0": "8.18.0",
            "fast-xml-parser@>=4.0.0 <5.5.6": "5.5.6",
            "minimatch@<3.1.4": ">=3.1.4",
            "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
            "serialize-javascript@<=7.0.2": ">=7.0.3",
            "happy-dom@<20.0.0": ">=20.0.0",
            "svgo@>=3.0.0 <3.3.3": ">=3.3.3",
            "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
            "undici@>=7.0.0 <7.24.4": "7.24.4",
            "wrangler@>=4.0.0 <4.59.1": ">=4.59.1"
        }
    }
}
