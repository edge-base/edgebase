# EdgeBase development environment variables
# Copy to .env.development for local dev, or to .dev.vars if you prefer Wrangler secrets.
# Keep real secrets out of git.

# Local auth/admin token signing secrets
JWT_USER_SECRET=
JWT_ADMIN_SECRET=

# Optional. Needed for Admin SDK access and some migration/admin flows in local dev.
# SERVICE_KEY=test-service-key-for-admin

# Optional PostgreSQL connection strings for namespaces/auth using provider: 'postgres'
# DB_POSTGRES_APP_URL=postgres://user:pass@host/db?sslmode=require
# AUTH_POSTGRES_URL=postgres://user:pass@host/db?sslmode=require

# Optional auth UX / local delivery helpers
# EDGEBASE_AUTH_BASE_URL=http://localhost:8787
# EDGEBASE_AUTH_FORCE_LOCAL_DELIVERY=1
# EDGEBASE_APP_WEB_CALLBACK_URL=http://localhost:3000/auth/callback
# EDGEBASE_APP_WEB_MAGIC_LINK_URL=http://localhost:3000/auth/magic-link
# EDGEBASE_APP_WEB_RESET_PASSWORD_URL=http://localhost:3000/auth/reset-password
# EDGEBASE_APP_WEB_VERIFY_EMAIL_URL=http://localhost:3000/auth/verify-email
# EDGEBASE_APP_WEB_CHANGE_EMAIL_URL=http://localhost:3000/auth/change-email

# Optional email provider settings
# EDGEBASE_EMAIL_PROVIDER=resend
# EDGEBASE_EMAIL_API_KEY=
# EDGEBASE_EMAIL_FROM=noreply@edgebase.fun

# Optional OAuth settings
# EDGEBASE_AUTH_ALLOWED_OAUTH_PROVIDERS=google,github
# EDGEBASE_OAUTH_GOOGLE_CLIENT_ID=
# EDGEBASE_OAUTH_GOOGLE_CLIENT_SECRET=
# EDGEBASE_OAUTH_GITHUB_CLIENT_ID=
# EDGEBASE_OAUTH_GITHUB_CLIENT_SECRET=
