{
    "name": "@edgebase/dashboard",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite dev",
        "preview": "vite preview",
        "lint": "svelte-check --tsconfig ./tsconfig.json",
        "check": "svelte-check --tsconfig ./tsconfig.json",
        "test": "vitest run && svelte-check --tsconfig ./tsconfig.json",
        "test:ui": "vitest run",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:live": "playwright test --config playwright.live.config.ts",
        "test:e2e:live:headed": "playwright test --config playwright.live.config.ts --headed"
    },
    "devDependencies": {
        "@codemirror/autocomplete": "^6.20.1",
        "@codemirror/commands": "^6.10.2",
        "@codemirror/lang-html": "^6.4.9",
        "@codemirror/lang-sql": "^6.10.0",
        "@codemirror/language": "^6.12.2",
        "@codemirror/state": "^6.5.4",
        "@codemirror/theme-one-dark": "^6.1.3",
        "@codemirror/view": "^6.39.16",
        "@playwright/test": "^1.49.0",
        "@sveltejs/adapter-static": "^3.0.8",
        "@sveltejs/kit": "^2.16.0",
        "@sveltejs/vite-plugin-svelte": "^5.0.0",
        "@testing-library/jest-dom": "^6.0.0",
        "@testing-library/svelte": "^5.3.1",
        "jsdom": "^24.0.0",
        "svelte": "^5.0.0",
        "svelte-check": "^4.0.0",
        "typescript": "^5.7.0",
        "vite": "^6.0.0",
        "vitest": "^3.2.4"
    }
}
