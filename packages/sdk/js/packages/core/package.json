{
    "name": "@edgebase-fun/core",
    "version": "0.1.0",
    "description": "EdgeBase core SDK — platform-agnostic client for auth, database, storage, and functions",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/edge-base/edgebase.git",
        "directory": "packages/sdk/js/packages/core"
    },
    "homepage": "https://edgebase.fun",
    "bugs": "https://github.com/edge-base/edgebase/issues",
    "keywords": [
        "edgebase",
        "sdk",
        "baas",
        "backend",
        "cloudflare-workers"
    ],
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "vitest run test/unit/",
        "prepack": "pnpm run build"
    },
    "dependencies": {
        "@edgebase-fun/shared": "workspace:*"
    },
    "devDependencies": {
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    }
}
