{
    "name": "@edgebase/web",
    "version": "0.1.0",
    "description": "EdgeBase web SDK — browser client with database-live subscriptions, room, and auth persistence",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/edgebase/edgebase.git",
        "directory": "packages/sdk/js/packages/web"
    },
    "homepage": "https://edgebase.fun",
    "bugs": "https://github.com/edgebase/edgebase/issues",
    "keywords": ["edgebase", "sdk", "web", "database-live", "baas"],
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "tsc --noEmit && vitest run test/unit/"
    },
    "dependencies": {
        "@edgebase/core": "workspace:*"
    },
    "devDependencies": {
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    }
}
