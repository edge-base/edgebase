{
    "name": "@edge-base/web",
    "version": "0.2.3",
    "description": "EdgeBase web SDK — browser client with database-live subscriptions, room, and auth persistence",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/edge-base/edgebase.git",
        "directory": "packages/sdk/js/packages/web"
    },
    "homepage": "https://github.com/edge-base/edgebase/tree/main/packages/sdk/js/packages/web",
    "bugs": "https://github.com/edge-base/edgebase/issues",
    "keywords": [
        "edgebase",
        "sdk",
        "web",
        "database-live",
        "baas"
    ],
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "files": [
        "dist",
        "llms.txt"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "tsc --noEmit && vitest run test/unit/",
        "prepack": "pnpm run build"
    },
    "dependencies": {
        "@cloudflare/realtimekit": "1.2.5",
        "@edge-base/core": "workspace:*"
    },
    "devDependencies": {
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    }
}
