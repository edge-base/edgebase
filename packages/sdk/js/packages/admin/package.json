        "dev": "tsc --watch",
        "test": "vitest run test/unit/",
        "prepack": "pnpm run build"
    },
    "dependencies": {
        "@codemirror/lang-html": "^6.4.11",
        "@edgebase-fun/core": "workspace:*"
    },
    "devDependencies": {
        "fast-check": "^4.5.3",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
