{
    "name": "@edge-base/react-native",
    "version": "0.2.5",
    "description": "EdgeBase React Native SDK — iOS, Android, Web support",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/edge-base/edgebase.git",
        "directory": "packages/sdk/react-native"
    },
    "homepage": "https://github.com/edge-base/edgebase/tree/main/packages/sdk/react-native",
    "bugs": "https://github.com/edge-base/edgebase/issues",
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "llms.txt"
    ],
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "test:e2e": "vitest run --config vitest.e2e.config.ts",
        "test:watch": "vitest",
        "type-check": "tsc --noEmit",
        "prepack": "pnpm run build"
    },
    "dependencies": {
        "@edge-base/core": "workspace:*"
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-native": ">=0.77.0",
        "@react-native-async-storage/async-storage": ">=1.21.0",
        "react-native-webview": ">=13.0.0",
        "@cloudflare/realtimekit-react-native": ">=0.3.1",
        "@cloudflare/react-native-webrtc": ">=125.0.3"
    },
    "peerDependenciesMeta": {
        "@cloudflare/realtimekit-react-native": {
            "optional": true
        },
        "@cloudflare/react-native-webrtc": {
            "optional": true
        },
        "react-native-webview": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/react": "^19.2.2",
        "@types/react-native": "^0.73.0",
        "tsup": "^8.0.0",
        "typescript": "^5.4.0",
        "vitest": "^1.6.0"
    }
}
