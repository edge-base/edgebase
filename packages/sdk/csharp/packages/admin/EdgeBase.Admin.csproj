<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <RootNamespace>EdgeBase.Admin</RootNamespace>
    <AssemblyName>EdgeBase.Admin</AssemblyName>
    <Nullable>enable</Nullable>
    <LangVersion>10.0</LangVersion>
    <PackageId>dev.edgebase.admin</PackageId>
    <Version>0.2.2</Version>
    <Description>EdgeBase Admin SDK for .NET - server-side auth, SQL, storage, push, analytics, KV, D1, and Vectorize</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://edgebase.fun/docs/database/admin-sdk</PackageProjectUrl>
    <RepositoryUrl>https://github.com/edge-base/edgebase/tree/main/packages/sdk/csharp/packages/admin</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="System.Text.Json" Version="8.0.5" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" />
    <None Include="llms.txt" Pack="true" PackagePath="" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\core\EdgeBase.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="tests/**" />
  </ItemGroup>
</Project>
