<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <RootNamespace>EdgeBase.Unity.Tests</RootNamespace>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <ImplicitUsings>disable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit" Version="2.6.1" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.5.7" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
  </ItemGroup>

  <!-- SDK source는 ProjectReference로 참조 -->
  <ItemGroup>
    <ProjectReference Include="../../core/EdgeBase.Core.csproj" />
    <ProjectReference Include="../EdgeBase.Unity.csproj" />
  </ItemGroup>

  <!-- test files -->
  <ItemGroup>
    <Compile Include="UnityUnitTests.cs" />
    <Compile Include="UnityE2ETests.cs" />
  </ItemGroup>
</Project>
